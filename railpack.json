{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "steps": {
    "runtime": {
      "inputs": [{ "image": "nginx:1.27-alpine" }],
      "commands": [
        "mkdir -p /var/log/nginx /var/run /etc/nginx /app",
        { "src": "nginx.conf", "dest": "/etc/nginx/nginx.conf" },
        { "src": "entrypoint.sh", "dest": "/app/entrypoint.sh" },
        "chmod +x /app/entrypoint.sh"
      ]
    }
  },
  "deploy": {
    "base": { "image": "nginx:1.27-alpine" },
    "inputs": [
      { "step": "runtime", "include": ["/etc/nginx/nginx.conf", "/app/entrypoint.sh"] },
      { "step": "build", "include": ["/app/dist"] }
    ],
    "startCommand": "/bin/sh /app/entrypoint.sh"
  }
}
