{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "secrets": [
    "VITE_TEST_BUILDTIME",
    "VITE_TEST_RUNTIME",
    "VITE_APP_URL"
  ],
  "steps": {
    "build": {
      "inputs": [{ "step": "install" }],
      "secrets": ["VITE_TEST_BUILDTIME", "VITE_TEST_RUNTIME", "VITE_APP_URL"],
      "commands": [
        { "src": "src", "dest": "src" },
        { "src": "public", "dest": "public" },
        { "src": "index.html", "dest": "index.html" },
        { "src": "tsconfig.json", "dest": "tsconfig.json" },
        { "src": "tsconfig.app.json", "dest": "tsconfig.app.json" },
        { "src": "tsconfig.node.json", "dest": "tsconfig.node.json" },
        { "src": "vite.config.ts", "dest": "vite.config.ts" },
        "npm run build"
      ]
    },
    "runtime": {
      "inputs": [{ "image": "nginx:1.27-alpine" }],
      "commands": [
        "apk add --no-cache dumb-init",
        "mkdir -p /var/log/nginx /var/run /etc/nginx /app",
        { "src": "entrypoint.sh", "dest": "/app/entrypoint.sh" },
        "chmod +x /app/entrypoint.sh"
      ]
    }
  },
  "deploy": {
    "base": { "step": "runtime" },
    "inputs": [{ "step": "build", "include": ["/app/dist"] }],
    "startCommand": "/bin/sh /app/entrypoint.sh"
  }
}
